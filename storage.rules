rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function memberDocId(projectId) {
      return projectId + '_' + request.auth.uid;
    }

    function isProjectMember(projectId) {
      return isSignedIn() &&
        firestore.exists(/databases/(default)/documents/project_members/$(memberDocId(projectId)));
    }

    match /project_photos/{projectId}/{fileName} {
      allow read: if isProjectMember(projectId);
      allow write: if isProjectMember(projectId);
    }
  }
}
